--  Helper: build an item slot Frame
-- ══════════════════════════════════════════════════════════════════════════════
local function buildSlot(parent, itemData, isYours, slotIndex)
    local slot = makeFrame(parent, UDim2.new(0,90,0,90), UDim2.new(0,0,0,0),
        itemData and rarityColor(itemData.Rarity) or Color3.fromRGB(50,50,60))
    slot.BackgroundTransparency = itemData and 0.5 or 0.6
 
    if itemData then
        local img = Instance.new("ImageLabel")
        img.Size = UDim2.new(1,-4,1,-20)
        img.Position = UDim2.new(0,2,0,2)
        img.BackgroundTransparency = 1
        img.Image = itemData.Image and
            ("rbxassetid://"..tostring(itemData.Image)) or ""
        img.Parent = slot
 
        local nameLbl = makeLabel(slot, itemData.ItemName or itemData.Name or "?",
            UDim2.new(1,0,0,18), UDim2.new(0,0,1,-18),
            Color3.new(1,1,1), 11, Enum.Font.Gotham)
        nameLbl.BackgroundColor3 = rarityColor(itemData.Rarity)
        nameLbl.BackgroundTransparency = 0.2
        nameLbl.TextXAlignment = Enum.TextXAlignment.Center
 
        if isYours then
            local rmBtn = makeButton(slot, "✕",
                UDim2.new(0,18,0,18), UDim2.new(1,-20,0,2),
                Color3.fromRGB(180,40,40))
            rmBtn.ZIndex = 10
            rmBtn.MouseButton1Click:Connect(function()
                RE_RemoveOffer:FireServer(itemData.DataID or itemData.Name, itemData.DataType or "Weapons")
            end)
        end
    else
        makeLabel(slot, "+", UDim2.new(1,0,1,0), UDim2.new(0,0,0,0),
            Color3.fromRGB(100,100,120), 28)
    end
    return slot
end
 
