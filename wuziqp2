    img.Size = UDim2.new(1,-4,0,80)
    img.Position = UDim2.new(0,2,0,2)
    img.BackgroundTransparency = 1
    img.Image = itemData.Image and ("rbxassetid://"..tostring(itemData.Image)) or ""
