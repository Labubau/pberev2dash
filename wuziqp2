    RE_SendRequest.OnClientInvoke = function(senderPlayer)
        if requestsEnabled then
            updateRequestWindow("ReceivingRequest", { Sender = { Name = senderPlayer.Name } })
        end
        return requestsEnabled
    end
end)
 
