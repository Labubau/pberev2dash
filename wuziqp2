-- ══════════════════════════════════════════════════════════════════════════════
--  Render offer panels
-- ══════════════════════════════════════════════════════════════════════════════
local function renderOfferPanel(slotsParent, offerTable, isYours)
    for _, ch in ipairs(slotsParent:GetChildren()) do
        if ch:IsA("Frame") then ch:Destroy() end
    end
    local count = 0
    for slot, item in pairs(offerTable) do
        count += 1
        buildSlot(slotsParent, item, isYours, slot)
    end
    for i = count+1, MAX_OFFER_SLOTS do
        buildSlot(slotsParent, nil, false, i)
    end
end
 
-- ══════════════════════════════════════════════════════════════════════════════
--  Populate inventory browser from ProfileData / existing API
-- ══════════════════════════════════════════════════════════════════════════════
local function populateInventory()
    -- Clear existing items
    for _, ch in ipairs(InvScroll:GetChildren()) do
        if not ch:IsA("UIListLayout") then ch:Destroy() end
    end
 
    -- Try to get inventory data from the game's existing modules
    local ok, ProfileData = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("ProfileData"))
    end)
    if not ok or not ProfileData then return end
 
    local profile = ProfileData.GetProfile and ProfileData.GetProfile()
    if not profile then return end
 
    local Sync = require(ReplicatedStorage:WaitForChild("Database"):WaitForChild("Sync"))
 
    -- Show Weapons and Pets (tradeable categories)
    for _, category in ipairs({"Weapons", "Pets"}) do
        local owned = profile[category] and profile[category].Owned or {}
        for itemID, _ in pairs(owned) do
            local itemDef = Sync[category] and Sync[category][itemID]
            if itemDef then
                local itemData = {}
                for k,v in pairs(itemDef) do itemData[k] = v end
                itemData.DataID   = itemID
                itemData.DataType = category
                itemData.Rarity   = itemData.Rarity or "Common"
                buildInvItem(InvScroll, itemData)
            end
        end
    end
end
 
-- ══════════════════════════════════════════════════════════════════════════════
--  Request window helpers
-- ══════════════════════════════════════════════════════════════════════════════
local function showRequestPanel(panel)
    Sending.Visible   = (panel == "Sending")
    Receiving.Visible = (panel == "Receiving")
    RequestBG.Visible = (panel ~= nil)
end
 
local function updateRequestWindow(state, data)
    if state == "SendingRequest" then
        SendingName.Text = data and data.Receiver and data.Receiver.Name or "..."
        showRequestPanel("Sending")
    elseif state == "ReceivingRequest" then
        RecvName.Text = data and data.Sender and data.Sender.Name or "..."
        showRequestPanel("Receiving")
    else
        showRequestPanel(nil)
    end
end
 
-- ══════════════════════════════════════════════════════════════════════════════
--  Trade window update (called on TradeUpdate event)
-- ══════════════════════════════════════════════════════════════════════════════
local function onTradeUpdate(tradeData)
    if not tradeData then
        -- Trade ended / cancelled
        inTrade = false
        TradeWindow.Visible = false
        myOffer = {}
        theirOffer = {}
        tradePartner = nil
        return
    end
 
    inTrade = true
    TradeWindow.Visible = true
    populateInventory()
 
    -- Determine which player slot we are
    local myKey, theirKey
    if tradeData.Player1 and tradeData.Player1.Player == LocalPlayer then
        myKey, theirKey = "Player1", "Player2"
    elseif tradeData.Player2 and tradeData.Player2.Player == LocalPlayer then
        myKey, theirKey = "Player2", "Player1"
    else
        return
    end
 
    -- Translate offer arrays to keyed tables
    myOffer    = {}
    theirOffer = {}
    if tradeData[myKey] then
        for i, v in ipairs(tradeData[myKey].Offer or {}) do
            myOffer[i] = {
                ItemID   = v[1] or v.ItemID,
                Amount   = v[2] or v.Amount,
                ItemType = v[3] or v.ItemType,
                DataID   = v[1] or v.ItemID,
                DataType = v[3] or v.ItemType,
                ItemName = v[1] or v.ItemID,
                Rarity   = "Common",
            }
        end
        myAccepted = tradeData[myKey].Accepted or false
    end
    if tradeData[theirKey] then
        for i, v in ipairs(tradeData[theirKey].Offer or {}) do
            theirOffer[i] = {
                ItemID   = v[1] or v.ItemID,
                Amount   = v[2] or v.Amount,
                ItemType = v[3] or v.ItemType,
                DataID   = v[1] or v.ItemID,
                DataType = v[3] or v.ItemType,
                ItemName = v[1] or v.ItemID,
                Rarity   = "Common",
            }
        end
        theirAccepted   = tradeData[theirKey].Accepted or false
        tradePartner    = tradeData[theirKey].Player
        PartnerLabel.Text = "Trading with: " .. (tradePartner and tradePartner.Name or "?")
        TheirName.Text    = tradePartner and tradePartner.Name or ""
    end
 
    -- Re-render slots
    renderOfferPanel(YourSlots,  myOffer,    true)
    renderOfferPanel(TheirSlots, theirOffer, false)
 
    YourAcceptedBadge.Visible  = myAccepted
    TheirAcceptedBadge.Visible = theirAccepted
    AcceptTradeBtn.Text        = myAccepted and "✔ Accepted" or "Accept Trade"
    AcceptTradeBtn.BackgroundColor3 = myAccepted
        and Color3.fromRGB(0,140,60) or Color3.fromRGB(0,180,80)
end
 
