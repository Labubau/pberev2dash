-- ─── Rarity Colours (mirrors the game's Sync.Rarities) ──────────────────────
local RARITY_COLORS = {
    Common       = Color3.fromRGB(170, 170, 170),
    Uncommon     = Color3.fromRGB(0,   200,  80),
    Rare         = Color3.fromRGB(0,   140, 255),
    Epic         = Color3.fromRGB(160,  50, 230),
    Legendary    = Color3.fromRGB(255, 175,   0),
    Ancient      = Color3.fromRGB(220,  50,  50),
    Godly        = Color3.fromRGB(255, 215,   0),
    Unique       = Color3.fromRGB(255, 105, 180),
}
local function rarityColor(rarity)
    return RARITY_COLORS[rarity] or RARITY_COLORS.Common
end
 
